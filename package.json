{
  "name": "@jiji-hoon96/oxdoc",
  "version": "0.2.0",
  "description": "Native-speed TypeScript/JavaScript API documentation generator powered by OXC",
  "type": "module",
  "bin": {
    "oxdoc": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test",
    "oxdoc": "tsx src/cli/index.ts",
    "bench": "tsx benchmarks/run.ts"
  },
  "keywords": [
    "typescript",
    "javascript",
    "documentation",
    "api-docs",
    "jsdoc",
    "tsdoc",
    "oxc",
    "doc-generator",
    "coverage",
    "doctest",
    "llms-txt"
  ],
  "author": "jiji-hoon96",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jiji-hoon96/oxdoc.git"
  },
  "homepage": "https://oxdoc.vercel.app",
  "bugs": {
    "url": "https://github.com/jiji-hoon96/oxdoc/issues"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "comment-parser": "^1.4.5",
    "fast-glob": "^3.3.3",
    "oxc-parser": "^0.121.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
